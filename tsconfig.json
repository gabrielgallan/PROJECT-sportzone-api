{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"],
    },

    "module": "ESNext",            // <- Usa import/export moderno
    "target": "ES2020",            // OK para Node moderno
    "moduleResolution": "Node",

    "strict": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,

    "noEmit": true,
    "allowImportingTsExtensions": true,

    "types": [
      "vitest/globals"
    ]
  },
  "exclude": ["dist", "node_modules"]
}